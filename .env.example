# ============================================
# Real-Time Inventory & Recommendation System
# Environment Variables
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env

# ── PostgreSQL ──
POSTGRES_DB=inventory_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme_postgres_2024
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_2024

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# ── Elasticsearch ──
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ── Service Ports ──
API_GATEWAY_PORT=8080
INVENTORY_SERVICE_PORT=8081
RECOMMENDATION_SERVICE_PORT=8082
FORECASTING_SERVICE_PORT=8083
PRICING_SERVICE_PORT=8084
WEBSOCKET_GATEWAY_PORT=8085
ANALYTICS_SERVICE_PORT=8086
REORDER_AGENT_PORT=8087

# ── Grafana ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Docker Hub (CI/CD only) ──
# DOCKER_USERNAME=your_dockerhub_username
# DOCKER_PASSWORD=your_dockerhub_password

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ── Cache ──
CACHE_TTL_SECONDS=300

# ── ML Model ──
MODEL_RETRAIN_INTERVAL_HOURS=24
COLD_START_THRESHOLD=3

# ── Reorder Agent (Groq LLM) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AGENT_RUN_INTERVAL_HOURS=6
SUPPLIER_LEAD_TIME_DAYS=3
MAX_REORDER_BUDGET_USD=5000
